{
  "manifest_version": 3,
  "name": "VKMuz",
  "version": "1.0",
  "description": "Adds 'SK' next to track actions on VK",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://vk.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
